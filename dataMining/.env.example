# MongoDB Configuration
# URL to MongoDB instance (local or remote)
MONGODB_URL=mongodb://localhost:27017
# Database name to store pull request data
MONGODB_DATABASE=PReQual
# Connection timeout for MongoDB operations
MONGODB_TIMEOUT=30s

# GitHub Configuration
# GitHub personal access tokens (comma-separated for rate limit handling)
# Get tokens from https://github.com/settings/tokens
GH_TOKENS=token1,token2,token3
# HTTP timeout for GitHub API requests
GH_TIMEOUT=10s
# Maximum retry attempts for failed GitHub API calls
GH_MAX_RETRY=3

# SonarQube Configuration
# Base URL of SonarQube instance
SONAR_URL=http://localhost:9000
# SonarQube token for authentication
# Get from: http://localhost:9000/account/security/
SONAR_TOKEN=squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Timeout for SonarQube analysis requests
SONAR_TIMEOUT=60s
# Interval between analysis status checks
SONAR_POLL_INTERVAL=5s

# Application Configuration
# Directory to store workspace and temporary files
WORKSPACE=./workspace
# Log level: debug, info, warn, error
LOG_LEVEL=info
